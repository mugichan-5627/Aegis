{
  "version": 2,
  "builds": [
    { "src": "api/tribunal.py",    "use": "@vercel/python", "config": { "maxDuration": 60 } },
    { "src": "api/watchtower.py",  "use": "@vercel/python", "config": { "maxDuration": 30 } },
    { "src": "api/valuation.py",   "use": "@vercel/python", "config": { "maxDuration": 15 } },
    { "src": "api/llm_patch.py",   "use": "@vercel/python", "config": { "maxDuration": 30 } },
    { "src": "index.html",         "use": "@vercel/static" }
  ],
  "crons": [
    { "path": "/api/watchtower", "schedule": "0 0 * * *" }
  ],
  "routes": [
    { "src": "/api/watchtower",  "dest": "api/watchtower.py" },
    { "src": "/api/tribunal",    "dest": "api/tribunal.py" },
    { "src": "/api/valuation",   "dest": "api/valuation.py" },
    { "src": "/api/llm_patch",    "dest": "api/llm_patch.py" },
    { "src": "/(.*)",            "dest": "index.html" }
  ]
}
