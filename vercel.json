{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "functions": {
    "api/tribunal.py":    { "maxDuration": 30 },
    "api/watchtower.py":  { "maxDuration": 30 },
    "api/valuation.py":   { "maxDuration": 15 },
    "api/codex_patch.py": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/watchtower", "schedule": "0 * * * *" }
  ],
  "routes": [
    { "src": "/api/watchtower",  "dest": "api/watchtower.py" },
    { "src": "/api/tribunal",    "dest": "api/tribunal.py" },
    { "src": "/api/valuation",   "dest": "api/valuation.py" },
    { "src": "/api/codex_patch", "dest": "api/codex_patch.py" },
    { "src": "/(.*)",            "dest": "index.html" }
  ]
}
